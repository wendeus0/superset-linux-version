# Maintainer: Superset Linux Team <linux@superset.sh>

pkgname=superset-bin
pkgver=1.3.2
pkgrel=1
pkgdesc="Superset Desktop - The last developer tool you'll ever need"
arch=('x86_64')
url="https://github.com/superset-sh/superset"
license=('MIT')
depends=('gtk3' 'libnotify' 'nss' 'libxss' 'libxtst' 'xdg-utils' 'at-spi2-core' 'libappindicator-gtk3')
optdepends=('libsecret: keychain integration')
provides=('superset')
conflicts=('superset')
source_x86_64=("superset-${pkgver}-x64.AppImage::https://github.com/superset-sh/superset/releases/download/desktop-v${pkgver}/Superset-x86_64.AppImage")
sha256sums_x86_64=('f14967b97114f2665537a48b31f8c2d5fbee06b4def38d696e1394874c3fff0f')

package() {
  install -dm755 "$pkgdir/usr/bin"
  install -dm755 "$pkgdir/opt/superset"
  install -dm755 "$pkgdir/usr/share/applications"
  install -dm755 "$pkgdir/usr/share/icons/hicolor/512x512/apps"

  install -m755 "${srcdir}/superset-${pkgver}-x64.AppImage" "$pkgdir/opt/superset/superset.AppImage"

  cat > "$pkgdir/usr/bin/superset" << 'EOF'
#!/usr/bin/env bash
exec /opt/superset/superset.AppImage "$@"
EOF
  chmod 755 "$pkgdir/usr/bin/superset"

  cat > "$pkgdir/usr/share/applications/superset.desktop" << 'EOF'
[Desktop Entry]
Name=Superset
Comment=The last developer tool you'll ever need
Exec=/usr/bin/superset
Icon=superset
Terminal=false
Type=Application
Categories=Development;
EOF

  # Icon extraction is optional; keep package install resilient
  "$pkgdir/opt/superset/superset.AppImage" --appimage-extract usr/share/icons/hicolor/512x512/apps/superset.png >/dev/null 2>&1 || true
  if [[ -f squashfs-root/usr/share/icons/hicolor/512x512/apps/superset.png ]]; then
    install -m644 squashfs-root/usr/share/icons/hicolor/512x512/apps/superset.png "$pkgdir/usr/share/icons/hicolor/512x512/apps/superset.png"
    rm -rf squashfs-root
  fi
}
